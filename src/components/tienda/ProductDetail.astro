---
import Button from "../ui/Button.astro";
import Badge from "../ui/Badge.astro";

interface Props {
  name: string;
  category: string;
  price: number;
  originalPrice?: number;
  badge?: string;
  description: string;
}

const { name, category, price, originalPrice, badge, description } = Astro.props;
const discount = originalPrice ? Math.round((1 - price / originalPrice) * 100) : 0;
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
  <div>
    <div class="relative rounded-2xl bg-gradient-to-br from-primary-bg to-primary/5 p-12 flex items-center justify-center aspect-square">
      {badge && (
        <div class="absolute top-4 left-4 z-10">
          <Badge variant={badge === "Sale" ? "red" : "primary"}>{badge}</Badge>
        </div>
      )}
      <div class="w-full h-full bg-white/60 rounded-full flex items-center justify-center">
        <i class="ti ti-package text-8xl text-primary/30"></i>
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-6">
    <div>
      <a href="/tienda" class="text-sm text-primary hover:text-primary-dark font-medium mb-2 block">
        ← Volver a tienda
      </a>
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">{category}</p>
      <h1 class="text-3xl font-bold text-gray-900">{name}</h1>
    </div>

    <div class="flex items-center gap-1">
      {Array.from({ length: 5 }).map((_, i) => (
        <i class={`ti ti-star-filled text-sm ${i < 4 ? "text-yellow-400" : "text-gray-200"}`}></i>
      ))}
      <span class="text-sm text-gray-500 ml-2">(4.5) 30 reseñas</span>
    </div>

    <div class="flex items-baseline gap-3">
      <span class="text-3xl font-bold text-gray-900">${price.toFixed(2)}</span>
      {originalPrice && (
        <>
          <span class="text-lg line-through text-gray-400">${originalPrice.toFixed(2)}</span>
          <span class="text-sm font-semibold text-red-600 bg-red-50 px-2 py-0.5 rounded-full">{discount}% OFF</span>
        </>
      )}
    </div>

    <p class="text-gray-600 leading-relaxed">{description}</p>

    <div class="flex items-center gap-3">
      <span class="text-sm font-medium text-gray-700">Cantidad:</span>
      <div class="flex items-center border border-gray-300 rounded-lg">
        <button class="px-3 py-1.5 text-gray-500 hover:text-gray-700 border-r border-gray-300" disabled>-</button>
        <span class="px-4 py-1.5 text-sm font-medium">1</span>
        <button class="px-3 py-1.5 text-gray-500 hover:text-gray-700 border-l border-gray-300" disabled>+</button>
      </div>
    </div>

    <div class="flex gap-3">
      <Button variant="primary" size="lg" class="flex-1 justify-center">
        <i class="ti ti-shopping-bag"></i>
        Agregar al Carrito
      </Button>
      <button class="w-12 h-12 rounded-lg border border-gray-300 flex items-center justify-center text-gray-600 hover:border-primary hover:text-primary transition-all" title="Favoritos">
        <i class="ti ti-heart"></i>
      </button>
    </div>

    <div class="border-t border-gray-100 pt-6">
      <div class="grid grid-cols-2 gap-4 text-sm text-gray-600">
        <div class="flex items-center gap-2">
          <i class="ti ti-truck-delivery text-primary"></i>
          <span>Envíos a todos los Estados Unidos</span>
        </div>
        <div class="flex items-center gap-2">
          <i class="ti ti-refresh text-primary"></i>
          <span>Devoluciones gratis</span>
        </div>
        <div class="flex items-center gap-2">
          <i class="ti ti-shield text-primary"></i>
          <span>Pago seguro</span>
        </div>
        <div class="flex items-center gap-2">
          <i class="ti ti-clock text-primary"></i>
          <span>Entrega en 24-48 hrs</span>
        </div>
      </div>
    </div>
  </div>
</div>
