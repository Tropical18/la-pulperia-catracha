---
import Button from "../ui/Button.astro";
import { getAllCategories } from "../../data/products";

const categories = getAllCategories();

const icons: Record<string, string> = {
  "carnes": "ti-meat",
  "lacteos": "ti-droplet",
  "bebidas": "ti-bottle",
  "frijoles-y-arroz": "ti-plant-2",
  "refrescos-naturales": "ti-leaf",
};

const colors: Record<string, string> = {
  "carnes": "from-red-500 to-red-400",
  "lacteos": "from-blue-400 to-cyan-300",
  "bebidas": "from-green-400 to-emerald-300",
  "frijoles-y-arroz": "from-amber-500 to-yellow-400",
  "refrescos-naturales": "from-primary to-primary-dark",
};
---

<section class="py-16 lg:py-20 bg-white">
  <div class="container max-w-7xl mx-auto px-4">
    <div class="flex items-end justify-between mb-10">
      <div>
        <span class="inline-block px-3 py-1 bg-primary-bg text-primary text-sm font-medium rounded-full mb-4">
          Categorías
        </span>
        <h2 class="text-3xl font-bold text-gray-900">
          Descubre nuestras <span class="text-primary">categorías</span>
        </h2>
      </div>
      <Button variant="ghost" size="md" href="/tienda" class="hidden sm:inline-flex">
        Ver todo <i class="ti ti-arrow-right"></i>
      </Button>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {categories.map((cat) => (
        <a href={`/tienda/${cat.slug}`} class="group">
          <div class="rounded-xl border border-gray-200 p-6 text-center transition-all duration-300 hover:shadow-lg hover:border-primary/30">
            <div class={`w-16 h-16 mx-auto mb-4 rounded-xl bg-gradient-to-br ${colors[cat.slug] || "from-primary to-primary-dark"} flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-300`}>
              <i class={`ti ${icons[cat.slug] || "ti-box"} text-2xl text-white`}></i>
            </div>
            <h3 class="text-sm font-semibold text-gray-900 group-hover:text-primary transition-colors">{cat.name}</h3>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-6 text-center sm:hidden">
      <Button variant="ghost" size="md" href="/tienda">
        Ver todas las categorías <i class="ti ti-arrow-right"></i>
      </Button>
    </div>
  </div>
</section>
