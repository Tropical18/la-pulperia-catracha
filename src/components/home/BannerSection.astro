---
import Button from "../ui/Button.astro";
---

<section class="py-16">
  <div class="container max-w-7xl mx-auto px-4">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-honduras-blue via-primary to-primary-dark">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
      </div>
      <div class="relative z-10 flex flex-col lg:flex-row items-center gap-8 p-10 lg:p-16">
        <div class="lg:w-2/3">
          <span class="inline-block px-3 py-1 bg-white/20 text-white text-sm font-medium rounded-full mb-4 backdrop-blur-sm">
            🚚 Envíos a todos los Estados Unidos
          </span>
          <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4">
            ¡Primera compra con <span class="text-yellow-300">10% de descuento</span>!
          </h2>
          <p class="text-white/80 mb-6 max-w-lg">
            Usa el código <span class="bg-white/20 px-3 py-1 rounded font-mono text-white font-bold">CATRACHO10</span> en tu primer pedido y recibe tus productos favoritos con el sabor de Honduras.
          </p>
          <Button variant="outline" size="lg" href="/tienda" class="border-white text-white hover:bg-white hover:text-primary">
            Comprar Ahora
            <i class="ti ti-arrow-right"></i>
          </Button>
        </div>
        <div class="lg:w-1/3 flex justify-center">
          <div class="text-center">
            <div class="text-6xl mb-2">🇭🇳</div>
            <p class="text-white/80 text-sm">Orgullosamente<br />Hondureño</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
