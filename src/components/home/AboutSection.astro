---
const features = [
  {
    icon: "ti-award",
    title: "Calidad Catracha",
    desc: "Seleccionamos los mejores productos hondureños para ofrecerte la frescura y el sabor que mereces."
  },
  {
    icon: "ti-handshake",
    title: "Tradición y Confianza",
    desc: "Inspirados en las pulperías de barrio de Honduras, llevamos la tradición a la era digital."
  },
  {
    icon: "ti-truck-delivery",
    title: "Envíos a Todo Estados Unidos",
    desc: "Llegamos a todos los estados con entregas rápidas y seguras."
  }
];
---

<section id="sobre-nosotros" class="py-16 lg:py-24 bg-white">
  <div class="container max-w-7xl mx-auto px-4">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="inline-block px-3 py-1 bg-primary-bg text-primary text-sm font-medium rounded-full mb-4">
        Sobre Nosotros
      </span>
      <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Más que una tienda, una tradición <span class="text-primary">catracha</span>
      </h2>
      <p class="text-gray-600">
        En La Pulpería Catracha nos enorgullece ofrecer productos auténticos de Honduras. Desde los frijoles y el arroz hasta los dulces típicos que endulzan nuestros días, cada producto cuenta una historia.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {features.map((f) => (
        <div class="text-center p-8 rounded-2xl border border-gray-100 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 group">
          <div class="w-16 h-16 mx-auto mb-5 rounded-xl bg-primary-bg flex items-center justify-center group-hover:bg-primary transition-all duration-300">
            <i class={`ti ${f.icon} text-2xl text-primary group-hover:text-white transition-all duration-300`}></i>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-3">{f.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
