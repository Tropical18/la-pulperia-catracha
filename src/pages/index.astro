---
import ShopLayout from "../layouts/ShopLayout.astro";
import Hero from "../components/home/Hero.astro";
import FeaturesSection from "../components/home/FeaturesSection.astro";
import CategoriesPreview from "../components/home/CategoriesPreview.astro";
import AboutSection from "../components/home/AboutSection.astro";
import BannerSection from "../components/home/BannerSection.astro";
import TestimonialSection from "../components/home/TestimonialSection.astro";
import ProductGrid from "../components/tienda/ProductGrid.astro";
import Button from "../components/ui/Button.astro";
import { getAllProducts } from "../data/products";

const productos = getAllProducts();
const destacados = productos.slice(0, 5);
---

<ShopLayout title="La Pulpería Catracha — Tu pulpería de confianza, 100% Catracha">
  <Hero />
  <FeaturesSection />
  <CategoriesPreview />

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="container max-w-7xl mx-auto px-4">
      <div class="flex items-end justify-between mb-10">
        <div>
          <span class="inline-block px-3 py-1 bg-primary-bg text-primary text-sm font-medium rounded-full mb-4">
            Productos
          </span>
          <h2 class="text-3xl font-bold text-gray-900">
            Nuestros <span class="text-primary">productos</span>
          </h2>
        </div>
        <Button variant="ghost" size="md" href="/tienda" class="hidden sm:inline-flex">
          Ver todo <i class="ti ti-arrow-right"></i>
        </Button>
      </div>

      <ProductGrid productos={destacados} />
    </div>
  </section>

  <AboutSection />
  <BannerSection />
  <TestimonialSection />
</ShopLayout>
