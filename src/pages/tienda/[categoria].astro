---
import ShopLayout from "../../layouts/ShopLayout.astro";
import ProductGrid from "../../components/tienda/ProductGrid.astro";
import ProductFilters from "../../components/tienda/ProductFilters.astro";
import { getAllCategorySlugs, getProductsByCategory, getCategoryName } from "../../data/products";

export function getStaticPaths() {
  return getAllCategorySlugs().map((slug) => ({
    params: { categoria: slug },
  }));
}

const { categoria } = Astro.params;
const categoriaNombre = getCategoryName(categoria!);
const productos = getProductsByCategory(categoria!);
---

<ShopLayout title={`${categoriaNombre} — La Pulpería Catracha`} description={`Compra ${categoriaNombre} en La Pulpería Catracha. Productos frescos y tradicionales hondureños.`}>
  <section class="bg-gray-50 border-b border-gray-200">
    <div class="container max-w-7xl mx-auto px-4 py-8">
      <a href="/tienda" class="text-sm text-primary hover:text-primary-dark font-medium mb-2 block">← Todas las categorías</a>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{categoriaNombre}</h1>
      <p class="text-gray-600">{productos.length} producto(s) en {categoriaNombre}.</p>
    </div>
  </section>

  <section class="py-10">
    <div class="container max-w-7xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-8">
        <div class="lg:w-1/4">
          <ProductFilters />
        </div>
        <div class="lg:w-3/4">
          <ProductGrid productos={productos} />
        </div>
      </div>
    </div>
  </section>
</ShopLayout>
